# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Trading mode: "paper" or "live"
TRADE_MODE=paper

# METAR station (default: EGLC = London City Airport)
METAR_STATION=EGLC

# Intervals (seconds)
MARKET_REFRESH_INTERVAL=900
METAR_POLL_INTERVAL=60
HEARTBEAT_INTERVAL=300

# Risk limits
MAX_TRADE_SIZE_USDC=10.0
DEFAULT_TRADE_SIZE_USDC=5.0
DAILY_LOSS_LIMIT_USDC=50.0
MAX_OPEN_POSITIONS=20

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Polymarket CLOB (for future live trading)
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
POLY_WALLET_ADDRESS=
POLY_PRIVATE_KEY=
