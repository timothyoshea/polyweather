{
  "buildCommand": "",
  "outputDirectory": "public",
  "functions": {
    "api/scan.py": {
      "maxDuration": 120,
      "memory": 1024
    },
    "api/analyze.py": {
      "maxDuration": 300,
      "memory": 512
    },
    "api/dashboard_analysis.py": {
      "maxDuration": 300,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/sniper", "destination": "/sniper.html" },
    { "source": "/sniper/trades", "destination": "/sniper-trades.html" },
    { "source": "/sniper/history", "destination": "/sniper-history.html" },
    { "source": "/sniper/settings", "destination": "/sniper-settings.html" },
    { "source": "/", "destination": "/compare.html" },
    { "source": "/dashboard", "destination": "/compare.html" },
    { "source": "/scanner", "destination": "/index.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/pnl", "destination": "/pnl.html" },
    { "source": "/analysis", "destination": "/analysis.html" },
    { "source": "/compare", "destination": "/compare.html" },
    { "source": "/exits", "destination": "/exits.html" }
  ],
  "crons": [
    {
      "path": "/api/scan?mode=tomorrow",
      "schedule": "0,10,20,30,40,50 * * * *"
    },
    {
      "path": "/api/scan?mode=all",
      "schedule": "5,15,25,35,45,55 * * * *"
    },
    {
      "path": "/api/resolve",
      "schedule": "*/30 * * * *"
    }
  ]
}
